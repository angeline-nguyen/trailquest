{
  "name": "craftquest/craft-5-start",
  "description": "A Craft 5 starter project to use with CraftQuest.io training tutorials.",
  "authors": [
    {
      "name": "Ryan Irelan",
      "email": "ryan@craftquest.io",
      "homepage": "https://craftquest.io"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "craftcms/ckeditor": "^5.4.0",
    "craftcms/cms": "5.9.19",
    "craftcms/contact-form": "^3.1.0",
    "justinholtweb/craft-free-nav": "^5.0.1",
    "rynpsc/craft-phone-number": "^3.0.0",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.0.0",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "modules\\": "modules/"
    }
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example.dev', '.env');\""
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
